  class ValidatorException(message: String) : RuntimeException(message)

  class ValidationException(message: String, val errors: Map<String, List<String>>) : RuntimeException(message)

  object Validators {
    fun Is(value: Any?, constraint: Any?, msg: String) {
      if (value != constraint) throw ValidatorException(msg)
    }

    fun Min(value: Number?, min: Double, msg: String) {
      if (value == null || value.toDouble() < min) throw ValidatorException(msg)
    }

    fun Max(value: Number?, max: Double, msg: String) {
      if (value == null || value.toDouble() > max) throw ValidatorException(msg)
    }

    fun Length(value: String?, length: Int, msg: String) {
      if (value == null || value.length != length) throw ValidatorException(msg)
    }

    fun MinLength(value: String?, min: Int, msg: String) {
      if (value == null || value.length < min) throw ValidatorException(msg)
    }

    fun MaxLength(value: String?, max: Int, msg: String) {
      if (value == null || value.length > max) throw ValidatorException(msg)
    }

    fun Range(value: Number?, min: Double, max: Double, msg: String) {
      if (value == null) throw ValidatorException(msg)
      val n = value.toDouble()
      if (n < min || n > max) throw ValidatorException(msg)
    }

    fun Matches(value: String?, pattern: String, msg: String) {
      if (value == null || !Regex(pattern).containsMatchIn(value)) throw ValidatorException(msg)
    }

    fun Contains(value: String?, part: String, msg: String) {
      if (value == null || !value.contains(part)) throw ValidatorException(msg)
    }

    fun StartsWith(value: String?, prefix: String, msg: String) {
      if (value == null || !value.startsWith(prefix)) throw ValidatorException(msg)
    }

    fun EndsWith(value: String?, suffix: String, msg: String) {
      if (value == null || !value.endsWith(suffix)) throw ValidatorException(msg)
    }

    fun In(value: Any?, values: List<Any?>, msg: String) {
      if (!values.contains(value)) throw ValidatorException(msg)
    }

    fun IsEmail(value: String?, msg: String) {
      if (value == null || !Regex("^[^\\\\s@]+@[^\\\\s@]+\\\\.[^\\\\s@]+$").matches(value)) throw ValidatorException(msg)
    }

    fun IsNumber(value: Any?, msg: String) {
      if (value !is Number) throw ValidatorException(msg)
    }

    fun IsURL(value: String?, msg: String) {
      try {
        if (value == null) throw IllegalArgumentException()
        URI(value)
      } catch (_: Exception) {
        throw ValidatorException(msg)
      }
    }

    fun IsUUID(value: String?, msg: String) {
      try {
        if (value == null) throw IllegalArgumentException()
        UUID.fromString(value)
      } catch (_: Exception) {
        throw ValidatorException(msg)
      }
    }

    fun IsDate(value: String?, msg: String) {
      try {
        if (value == null) throw IllegalArgumentException()
        LocalDate.parse(value)
      } catch (_: Exception) {
        throw ValidatorException(msg)
      }
    }

    fun IsDateTime(value: String?, msg: String) {
      try {
        if (value == null) throw IllegalArgumentException()
        LocalDateTime.parse(value)
      } catch (_: Exception) {
        throw ValidatorException(msg)
      }
    }

    fun IsAlpha(value: String?, msg: String) {
      if (value == null || !Regex("^[A-Za-z]+$").matches(value)) throw ValidatorException(msg)
    }

    fun IsAlnum(value: String?, msg: String) {
      if (value == null || !Regex("^[A-Za-z0-9]+$").matches(value)) throw ValidatorException(msg)
    }

    fun NotNull(value: Any?, msg: String) {
      if (value == null) throw ValidatorException(msg)
    }

    fun IsBool(value: Any?, msg: String) {
      if (value !is Boolean) throw ValidatorException(msg)
    }
  }
