export class {{.Name}} extends Error {
{{- if .HasCode }}
  readonly code = {{.Code}};
{{- end }}
{{- if .HasScope }}
  readonly scope = {{.Scope}};
{{- end }}
{{- if .HasStatus }}
  readonly status = {{.Status}};
{{- end }}

  constructor() {
    super({{.Message}});
    this.name = "{{.Name}}";
  }
}
