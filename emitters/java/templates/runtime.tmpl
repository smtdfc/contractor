  public static class ValidatorException extends RuntimeException {
    public ValidatorException(String message) {
      super(message);
    }
  }

  public static class Validators {
    public static void Is(Object value, Object constraint, String msg) {
      if (!Objects.equals(value, constraint)) {
        throw new ValidatorException(msg);
      }
    }

    public static void Min(Number value, double min, String msg) {
      if (value == null || value.doubleValue() < min) {
        throw new ValidatorException(msg);
      }
    }

    public static void Max(Number value, double max, String msg) {
      if (value == null || value.doubleValue() > max) {
        throw new ValidatorException(msg);
      }
    }

    public static void Length(String value, int length, String msg) {
      if (value == null || value.length() != length) {
        throw new ValidatorException(msg);
      }
    }

    public static void MinLength(String value, int min, String msg) {
      if (value == null || value.length() < min) {
        throw new ValidatorException(msg);
      }
    }

    public static void MaxLength(String value, int max, String msg) {
      if (value == null || value.length() > max) {
        throw new ValidatorException(msg);
      }
    }

    public static void Range(Number value, double min, double max, String msg) {
      if (value == null) {
        throw new ValidatorException(msg);
      }

      double n = value.doubleValue();
      if (n < min || n > max) {
        throw new ValidatorException(msg);
      }
    }

    public static void Matches(String value, String pattern, String msg) {
      if (value == null || !Pattern.compile(pattern).matcher(value).find()) {
        throw new ValidatorException(msg);
      }
    }

    public static void Contains(String value, String part, String msg) {
      if (value == null || !value.contains(part)) {
        throw new ValidatorException(msg);
      }
    }

    public static void StartsWith(String value, String prefix, String msg) {
      if (value == null || !value.startsWith(prefix)) {
        throw new ValidatorException(msg);
      }
    }

    public static void EndsWith(String value, String suffix, String msg) {
      if (value == null || !value.endsWith(suffix)) {
        throw new ValidatorException(msg);
      }
    }

    public static void In(Object value, List<?> values, String msg) {
      if (values == null || !values.contains(value)) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsEmail(String value, String msg) {
      if (value == null || !value.matches("^[^\\\\s@]+@[^\\\\s@]+\\\\.[^\\\\s@]+$")) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsNumber(Object value, String msg) {
      if (!(value instanceof Number)) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsURL(String value, String msg) {
      try {
        new URI(value);
      } catch (Exception ex) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsUUID(String value, String msg) {
      try {
        UUID.fromString(value);
      } catch (Exception ex) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsDate(String value, String msg) {
      try {
        LocalDate.parse(value);
      } catch (Exception ex) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsDateTime(String value, String msg) {
      try {
        LocalDateTime.parse(value);
      } catch (Exception ex) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsAlpha(String value, String msg) {
      if (value == null || !value.matches("^[A-Za-z]+$")) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsAlnum(String value, String msg) {
      if (value == null || !value.matches("^[A-Za-z0-9]+$")) {
        throw new ValidatorException(msg);
      }
    }

    public static void NotNull(Object value, String msg) {
      if (value == null) {
        throw new ValidatorException(msg);
      }
    }

    public static void IsBool(Object value, String msg) {
      if (!(value instanceof Boolean)) {
        throw new ValidatorException(msg);
      }
    }
  }
