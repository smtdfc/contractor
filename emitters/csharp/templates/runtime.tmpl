    public sealed class ValidatorException : Exception
    {
        public ValidatorException(string message) : base(message) { }
    }

    public sealed class ValidationException : Exception
    {
        public IReadOnlyDictionary<string, List<string>> Errors { get; }

        public ValidationException(string message, Dictionary<string, List<string>> errors) : base(message)
        {
            Errors = errors;
        }
    }

    public static class Validators
    {
        public static void Is(object? value, object? constraint, string msg)
        {
            if (!Equals(value, constraint)) throw new ValidatorException(msg);
        }

        public static void Min(double? value, double min, string msg)
        {
            if (!value.HasValue || value.Value < min) throw new ValidatorException(msg);
        }

        public static void Max(double? value, double max, string msg)
        {
            if (!value.HasValue || value.Value > max) throw new ValidatorException(msg);
        }

        public static void Length(string? value, int length, string msg)
        {
            if (value is null || value.Length != length) throw new ValidatorException(msg);
        }

        public static void MinLength(string? value, int min, string msg)
        {
            if (value is null || value.Length < min) throw new ValidatorException(msg);
        }

        public static void MaxLength(string? value, int max, string msg)
        {
            if (value is null || value.Length > max) throw new ValidatorException(msg);
        }

        public static void Range(double? value, double min, double max, string msg)
        {
            if (!value.HasValue || value.Value < min || value.Value > max) throw new ValidatorException(msg);
        }

        public static void Matches(string? value, string pattern, string msg)
        {
            if (value is null || !Regex.IsMatch(value, pattern)) throw new ValidatorException(msg);
        }

        public static void Contains(string? value, string part, string msg)
        {
            if (value is null || !value.Contains(part)) throw new ValidatorException(msg);
        }

        public static void StartsWith(string? value, string prefix, string msg)
        {
            if (value is null || !value.StartsWith(prefix)) throw new ValidatorException(msg);
        }

        public static void EndsWith(string? value, string suffix, string msg)
        {
            if (value is null || !value.EndsWith(suffix)) throw new ValidatorException(msg);
        }

        public static void In(object? value, IEnumerable<object?> values, string msg)
        {
            if (!values.Contains(value)) throw new ValidatorException(msg);
        }

        public static void IsEmail(string? value, string msg)
        {
            if (value is null || !Regex.IsMatch(value, @"^[^\s@]+@[^\s@]+\.[^\s@]+$")) throw new ValidatorException(msg);
        }

        public static void IsNumber(object? value, string msg)
        {
            if (value is not sbyte and byte and short and ushort and int and uint and long and ulong and float and double and decimal)
                throw new ValidatorException(msg);
        }

        public static void IsURL(string? value, string msg)
        {
            if (value is null || !Uri.TryCreate(value, UriKind.Absolute, out _)) throw new ValidatorException(msg);
        }

        public static void IsUUID(string? value, string msg)
        {
            if (value is null || !Guid.TryParse(value, out _)) throw new ValidatorException(msg);
        }

        public static void IsDate(string? value, string msg)
        {
            if (value is null || !DateOnly.TryParse(value, out _)) throw new ValidatorException(msg);
        }

        public static void IsDateTime(string? value, string msg)
        {
            if (value is null || !DateTime.TryParse(value, out _)) throw new ValidatorException(msg);
        }

        public static void IsAlpha(string? value, string msg)
        {
            if (value is null || !Regex.IsMatch(value, "^[A-Za-z]+$")) throw new ValidatorException(msg);
        }

        public static void IsAlnum(string? value, string msg)
        {
            if (value is null || !Regex.IsMatch(value, "^[A-Za-z0-9]+$")) throw new ValidatorException(msg);
        }

        public static void NotNull(object? value, string msg)
        {
            if (value is null) throw new ValidatorException(msg);
        }

        public static void IsBool(object? value, string msg)
        {
            if (value is not bool) throw new ValidatorException(msg);
        }

        public static void ValidateModel(object? value, string msg)
        {
            if (value is null)
            {
                return;
            }

            var method = value.GetType().GetMethod("Validate", Type.EmptyTypes);
            if (method is null)
            {
                return;
            }

            try
            {
                method.Invoke(value, null);
            }
            catch
            {
                throw new ValidatorException(msg);
            }
        }

        private static Dictionary<string, List<string>> PrefixErrors(string path, IReadOnlyDictionary<string, List<string>> errors)
        {
            var prefixed = new Dictionary<string, List<string>>();
            foreach (var kv in errors)
            {
                var key = string.IsNullOrEmpty(kv.Key) ? path : $"{path}.{kv.Key}";
                prefixed[key] = new List<string>(kv.Value);
            }

            return prefixed;
        }

        public static void NestedValidate(object? value, string path, string msg)
        {
            if (value is null)
            {
                return;
            }

            if (value is IEnumerable items && value is not string)
            {
                var index = 0;
                foreach (var item in items)
                {
                    NestedValidate(item, $"{path}[{index}]", msg);
                    index++;
                }

                return;
            }

            var method = value.GetType().GetMethod("Validate", Type.EmptyTypes);
            if (method is null)
            {
                return;
            }

            try
            {
                method.Invoke(value, null);
            }
            catch (TargetInvocationException ex) when (ex.InnerException is ValidationException vex)
            {
                throw new ValidationException(vex.Message, PrefixErrors(path, vex.Errors));
            }
            catch (TargetInvocationException ex) when (ex.InnerException is ValidatorException vex)
            {
                throw new ValidationException("validation failed", new Dictionary<string, List<string>>
                {
                    [path] = new List<string> { vex.Message }
                });
            }
            catch
            {
                throw new ValidatorException(msg);
            }
        }
    }
